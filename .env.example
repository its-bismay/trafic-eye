# Database URL: Set to PostgreSQL / NeonDB. If left blank, it falls back to a local SQLite database.
# DATABASE_URL=postgresql://user:pass@localhost:5432/traffic_db

# JWT settings
JWT_SECRET=super-secret-key-for-traffic-violation-app-12345
JWT_EXPIRE_MINUTES=1440

# AWS S3 Settings: If left blank or missing, the platform automatically saves videos
# and annotated frames to the local disk (under backend/media/) and serves them via static mount.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=traffic-violations

# Local security key for signing media URLs if S3 is not used
LOCAL_URL_SIGNING_KEY=local-media-signing-secret-key
